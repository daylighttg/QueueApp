<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️ Settings"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="32dp" />

    <!-- ── Notification Settings ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notifications"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="12dp" />

    <!-- Alarm Sound Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔔 Alarm Sound"
            android:textSize="16sp"
            android:textColor="#444444" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchAlarmSound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
    </LinearLayout>

    <!-- Vibration Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📳 Vibration"
            android:textSize="16sp"
            android:textColor="#444444" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchVibration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="24dp" />

    <!-- ── Server Settings ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Server Connection"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <!-- Connection status -->
    <TextView
        android:id="@+id/tvConnectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Checking…"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="12dp" />

    <!-- Server URL Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Server URL"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etServerUrl"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="http://192.168.1.5:5000"
        android:textSize="15sp"
        android:inputType="textUri"
        android:background="@android:drawable/edit_text"
        android:padding="8dp"
        android:layout_marginBottom="12dp" />

    <!-- Auto-discover + Save buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnAutoDiscover"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🔍 Auto-Detect"
            android:textSize="13sp"
            android:backgroundTint="#43A047"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSaveServer"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="💾 Save URL"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- Test Connection button -->
    <Button
        android:id="@+id/btnTestConnection"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="🔗 Test Connection"
        android:textSize="14sp"
        android:backgroundTint="#FF8F00"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp" />

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Back Button -->
    <Button
        android:id="@+id/btnSettingsBack"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="⬅ Back"
        android:textSize="16sp"
        android:backgroundTint="#78909C"
        android:textColor="#FFFFFF" />

</LinearLayout>

