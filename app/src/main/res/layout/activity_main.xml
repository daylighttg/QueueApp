<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#FFFFFF">

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏥 Queue System"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="40dp" />

    <!-- Now Serving -->
    <TextView
        android:id="@+id/tvNowServing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Now Serving: —"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="16dp" />

    <!-- Waiting Count -->
    <TextView
        android:id="@+id/tvWaitingCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="People Waiting: —"
        android:textSize="18sp"
        android:textColor="#555555"
        android:layout_marginBottom="40dp" />

    <!-- Join Queue Button -->
    <Button
        android:id="@+id/btnJoinQueue"
        android:layout_width="250dp"
        android:layout_height="56dp"
        android:text="➕ Join Queue"
        android:textSize="18sp"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <!-- Refresh Button -->
    <Button
        android:id="@+id/btnRefresh"
        android:layout_width="250dp"
        android:layout_height="48dp"
        android:text="🔄 Refresh"
        android:textSize="16sp"
        android:backgroundTint="#78909C"
        android:textColor="#FFFFFF" />

</LinearLayout>

